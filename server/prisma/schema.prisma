generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Users & Skills ─────────────────────────────────────────

model User {
  id              String   @id @default(uuid())
  firebaseUid     String   @unique
  email           String   @unique
  name            String
  avatarUrl       String?
  bio             String?
  university      String?
  graduationYear  Int?
  githubUrl       String?
  linkedinUrl     String?
  experienceLevel ExperienceLevel @default(INTERMEDIATE)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  skills              UserSkill[]
  preferences         UserPreference?
  hackathonInterests  HackathonInterest[]
  teamMemberships     TeamMember[]
  sentInvites         TeamInvite[]       @relation("InviteSender")
  receivedInvites     TeamInvite[]       @relation("InviteReceiver")
  writtenReviews      Review[]           @relation("ReviewAuthor")
  receivedReviews     Review[]           @relation("ReviewTarget")
  notifications       Notification[]
  notificationPrefs   NotificationPreference?
  createdTeams        Team[]             @relation("TeamCreator")
  sentSwipes          Swipe[]            @relation("SwipeSender")
  receivedSwipes      Swipe[]            @relation("SwipeReceiver")
  matchesAsUserOne    Match[]            @relation("MatchUserOne")
  matchesAsUserTwo    Match[]            @relation("MatchUserTwo")
  matchesCreated      Match[]            @relation("MatchCreator")
  profile             UserProfile?
  chatMessages              ChatMessage[]              @relation("ChatMessageSender")
  conversationParticipations ConversationParticipant[] @relation("ConversationParticipantUser")
  messageReactions          MessageReaction[]          @relation("MessageReactionUser")
}

model UserProfile {
  id                        String          @id @default(uuid())
  userId                    String          @unique
  academicYear              String?
  major                     String?
  interests                 String[]        @default([])
  skills                    Json?
  aiScanSnapshot            Json?
  aiScanSeed                String?
  aiScanUpdatedAt           DateTime?
  assessmentResponses       Json?
  hackathonExperienceCount  Int             @default(0)
  hackathonExperienceNotes  String?
  portfolioLinks            Json?
  projectExperience         Json?
  workExperience            Json?
  photoDataUrl              String?
  showEmail                 Boolean         @default(false)
  showPortfolio             Boolean         @default(true)
  discoverable              Boolean         @default(true)
  githubVerified            Boolean         @default(false)
  linkedinVerified          Boolean         @default(false)
  universityVerified        Boolean         @default(false)
  onboardingCompleted       Boolean         @default(false)
  completion                Int             @default(0)
  internalSkillScore        Int             @default(0)
  internalSkillTier         ExperienceLevel @default(BEGINNER)
  githubScore               Int             @default(0)
  githubScoreUpdatedAt      DateTime?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Skill {
  id       String        @id @default(uuid())
  name     String        @unique
  category SkillCategory

  users UserSkill[]
}

enum SkillCategory {
  FRONTEND
  BACKEND
  MOBILE
  DATA
  DEVOPS
  DESIGN
  OTHER
}

model UserSkill {
  userId           String
  skillId          String
  proficiencyLevel Int    @default(3) // 1-5 scale

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
}

model UserPreference {
  id                      String   @id @default(uuid())
  userId                  String   @unique
  preferredExperienceLevels ExperienceLevel[]
  preferredSkillCategories  SkillCategory[]
  preferredTeamSize       Int?
  lookingFor              LookingFor[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum LookingFor {
  LEARN
  COMPETE
  NETWORK
}

// ─── Hackathons ─────────────────────────────────────────────

model Hackathon {
  id                   String   @id @default(uuid())
  name                 String
  description          String
  url                  String?
  imageUrl             String?
  startDate            DateTime
  endDate              DateTime
  registrationDeadline DateTime?
  location             String?
  isOnline             Boolean  @default(false)
  minTeamSize          Int      @default(1)
  maxTeamSize          Int      @default(5)
  difficultyLevel      ExperienceLevel @default(INTERMEDIATE)
  tags                 String[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  interests HackathonInterest[]
  teams     Team[]
}

model HackathonInterest {
  userId      String
  hackathonId String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@id([userId, hackathonId])
}

// ─── Swipes (Discover) ──────────────────────────────────────

model Swipe {
  id        String   @id @default(uuid())
  swiperId  String
  targetId  String
  direction String   // "left" or "right"
  createdAt DateTime @default(now())

  swiper User @relation("SwipeSender", fields: [swiperId], references: [id], onDelete: Cascade)
  target User @relation("SwipeReceiver", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([swiperId, targetId])
  @@index([targetId, direction])
}

// ─── Teams ──────────────────────────────────────────────────

model Team {
  id          String     @id @default(uuid())
  name        String
  hackathonId String
  createdById String
  status      TeamStatus @default(FORMING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  hackathon    Hackathon    @relation(fields: [hackathonId], references: [id])
  createdBy    User         @relation("TeamCreator", fields: [createdById], references: [id])
  members      TeamMember[]
  invites      TeamInvite[]
  reviews      Review[]
  conversation Conversation?
}

enum TeamStatus {
  FORMING
  COMPLETE
  COMPETING
  FINISHED
}

model TeamMember {
  teamId   String
  userId   String
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
}

enum TeamRole {
  LEADER
  MEMBER
}

model TeamInvite {
  id         String       @id @default(uuid())
  teamId     String
  fromUserId String
  toUserId   String
  status     InviteStatus @default(PENDING)
  message    String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  team     Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  fromUser User @relation("InviteSender", fields: [fromUserId], references: [id])
  toUser   User @relation("InviteReceiver", fields: [toUserId], references: [id])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── Reviews ────────────────────────────────────────────────

model Review {
  id           String       @id @default(uuid())
  authorId     String
  targetUserId String
  teamId       String
  rating       ReviewRating
  content      String
  isAnonymous  Boolean      @default(false)
  createdAt    DateTime     @default(now())

  author     User @relation("ReviewAuthor", fields: [authorId], references: [id])
  targetUser User @relation("ReviewTarget", fields: [targetUserId], references: [id])
  team       Team @relation(fields: [teamId], references: [id])
}

enum ReviewRating {
  POSITIVE
  NEGATIVE
}

// ─── Messaging ──────────────────────────────────────────────

enum ConversationType {
  DM
  TEAM
}

model Conversation {
  id              String           @id @default(uuid())
  type            ConversationType @default(DM)
  name            String?
  teamId          String?          @unique
  createdByUserId String
  lastMessageId   String?
  lastMessageAt   DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  team         Team?                      @relation(fields: [teamId], references: [id])
  participants ConversationParticipant[]
  messages     ChatMessage[]
}

model ConversationParticipant {
  id              String    @id @default(uuid())
  conversationId  String
  userId          String
  lastReadAt      DateTime?
  lastDeliveredAt DateTime?
  joinedAt        DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation("ConversationParticipantUser", fields: [userId], references: [firebaseUid])

  @@unique([conversationId, userId])
}

enum ChatMessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

model ChatMessage {
  id                 String          @id @default(uuid())
  conversationId     String
  senderId           String
  body               String?
  messageType        ChatMessageType @default(TEXT)
  attachmentUrl      String?
  attachmentName     String?
  attachmentMimeType String?
  attachmentSize     Int?
  linkPreviewJson    Json?
  clientMessageId    String?
  sentAt             DateTime        @default(now())
  editedAt           DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  conversation Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User             @relation("ChatMessageSender", fields: [senderId], references: [firebaseUid])
  reactions    MessageReaction[]

  @@index([conversationId, sentAt])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation("MessageReactionUser", fields: [userId], references: [firebaseUid])

  @@unique([messageId, userId, emoji])
}

model Match {
  id              String   @id @default(uuid())
  userOneId       String
  userTwoId       String
  status          String   @default("accepted")
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userOne   User @relation("MatchUserOne", fields: [userOneId], references: [id], onDelete: Cascade)
  userTwo   User @relation("MatchUserTwo", fields: [userTwoId], references: [id], onDelete: Cascade)
  createdBy User @relation("MatchCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@unique([userOneId, userTwoId])
}

// ─── Notifications ──────────────────────────────────────────

model Notification {
  id          String           @id @default(uuid())
  userId      String
  type        NotificationType
  title       String
  content     String
  relatedId   String?
  relatedType String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

enum NotificationType {
  TEAM_INVITE
  HACKATHON_ALERT
  REVIEW_RECEIVED
  TEAM_UPDATE
  SYSTEM
  NEW_MATCH
}

model NotificationPreference {
  id                 String  @id @default(uuid())
  userId             String  @unique
  hackathonAlerts    Boolean @default(true)
  teamInviteAlerts   Boolean @default(true)
  reviewAlerts       Boolean @default(true)
  emailNotifications Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
