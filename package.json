{
  "name": "codecollab",
  "version": "1.0.0",
  "description": "Smart hackathon teammate discovery platform for Singapore university students",
  "main": "index.js",
  "scripts": {
    "start": "cd client && npm start",
    "client": "cd client && npm start",
    "server": "cd server && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-client": "cd client && npm install",
    "install-server": "cd server && npm install",
    "install-all": "npm install && npm run install-client && npm run install-server",
    "build": "cd client && npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/CodeCollab.git"
  },
  "keywords": [
    "hackathon",
    "collaboration",
    "team-formation",
    "matching",
    "students",
    "singapore"
  ],
  "author": "G3T3 - Singapore Management University",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/yourusername/CodeCollab/issues"
  },
  "homepage": "https://github.com/yourusername/CodeCollab#readme",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
