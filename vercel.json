{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd client && ./node_modules/.bin/react-scripts build",
  "outputDirectory": "client/build",
  "functions": {
    "api/index.js": {
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
