{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && cd client && npm install --include=dev --legacy-peer-deps && cd ../server && npm install && npx prisma generate",
  "buildCommand": "npm run build --prefix client",
  "outputDirectory": "client/build",
  "functions": {
    "api/index.js": {
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
