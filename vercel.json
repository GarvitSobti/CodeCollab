{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && cd client && rm -f package-lock.json && npm install --legacy-peer-deps && cd ../server && npm install && npx prisma generate",
  "buildCommand": "cd ./client && npm run build",
  "outputDirectory": "client/build",
  "functions": {
    "api/index.js": {
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
